{
    "name": "jury-voting-system-automation",
    "version": "1.0.0",
    "description": "Playwright TypeScript automation tests for GCA Jury Voting System",
    "scripts": {
          "test": "playwright test",
          "test:smoke": "playwright test --grep @smoke",
          "test:regression": "playwright test --grep @regression",
          "test:lang-ar": "playwright test --grep @lang-ar",
          "test:lang-en": "playwright test --grep @lang-en",
          "test:sp1793": "playwright test --grep @SP-1793",
          "test:sp1794": "playwright test --grep @SP-1794",
          "test:sp1795": "playwright test --grep @SP-1795",
          "test:sp1796": "playwright test --grep @SP-1796",
          "test:sp1797": "playwright test --grep @SP-1797",
          "test:sp1798": "playwright test --grep @SP-1798",
          "test:headed": "playwright test --headed",
          "report": "playwright show-report"
    },
    "devDependencies": {
          "@playwright/test": "^1.42.0",
          "@types/node": "^20.0.0",
          "typescript": "^5.0.0",
          "dotenv": "^16.0.0"
